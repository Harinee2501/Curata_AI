{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./**/*.jsx", "./**/*.js", "./vite.config.js"]
}
